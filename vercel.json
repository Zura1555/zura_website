{
  "buildCommand": "cd frontend; npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend; npm install",
  "devCommand": "cd frontend; npm run dev",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_SANITY_PROJECT_ID": "$NEXT_PUBLIC_SANITY_PROJECT_ID",
    "NEXT_PUBLIC_SANITY_DATASET": "$NEXT_PUBLIC_SANITY_DATASET",
    "NEXT_PUBLIC_SANITY_API_VERSION": "$NEXT_PUBLIC_SANITY_API_VERSION",
    "NEXT_PUBLIC_SANITY_STUDIO_URL": "$NEXT_PUBLIC_SANITY_STUDIO_URL",
    "SANITY_API_READ_TOKEN": "$SANITY_API_READ_TOKEN",
    "SANITY_API_TOKEN": "$SANITY_API_TOKEN"
  },
  "functions": {
    "frontend/src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/studio/:path*",
      "destination": "https://zura.sanity.studio/:path*"
    }
  ]
}